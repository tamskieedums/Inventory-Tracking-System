    public static void batch_sorter(ArrayList<Product> Batch) {
        boolean Swapped;
        int Size = Batch.size();
        do {
            Swapped = false;
            for (int i = 0; i < Size - 1; i++) {
                Product Temp_Product1 = Batch.get(i);
                Product Temp_Product2 = Batch.get(i + 1);

                if (Temp_Product1.Expiration_Date.isAfter(Temp_Product2.Expiration_Date)) {
                    Product Temp = Temp_Product1;
                    Batch.set(i, Temp_Product2);
                    Batch.set(i + 1, Temp);
                    Swapped = true;
                }
            }
        } while (Swapped);
    }
}


class Product {
    String Name;
    int Quantity;
    double Price;
    LocalDate Expiration_Date;

    Product(String Name, int Quantity, double Price, LocalDate Expiration_Date){
        this.Name = Name.toUpperCase();
        this.Quantity = Quantity;
        this.Price = Price;
        this.Expiration_Date = Expiration_Date;
    }
}


class Parent_Product {
    String Name;
    ArrayList<Product> Batch = new ArrayList<>();

    Parent_Product(String Name, ArrayList<Product> Batch){
        this.Name = Name.toUpperCase();
        this.Batch = Batch;
    }
}
